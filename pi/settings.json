{
  "defaultProvider": "easter-company",
  "defaultModel": "darwin-cloud-auto",
  "defaultThinkingLevel": "medium",
  "showHardwareCursor": true,
  "quietStartup": true,
  "enableInstallTelemetry": false,
  "doubleEscapeAction": "none",
  "treeFilterMode": "default",
  "compactTools": true,
  "models": "easter-company/darwin*,easter-company/gemini*",
  "hideFooter": true,
  "theme": "dark",
  "packages": [
    "/root/.pi/agent/packages/pi-annotate"
  ],
  "extensions": [
    "/root/.pi/agent/extensions/darwin-branding.ts",
    "/root/.pi/agent/extensions/monitor.ts",
    "/root/.pi/agent/extensions/provider-easter.ts",
    "/root/.pi/agent/extensions/etl.ts"
  ]
}
